{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 Debug (Cortex-Debug)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/CanSat_Final.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "stlink",
            "device": "STM32F411CE",
            "interface": "swd",
            "runToEntryPoint": "main",
            "armToolchainPath": "/home/gashadokuro/.local/share/stm32cube/bundles/gnu-tools-for-stm32/14.3.1+st.2/bin/",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
        {
            "name": "STM32 Debug (ST-Link)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/CanSat_Final.elf",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/home/gashadokuro/.local/share/stm32cube/bundles/gnu-tools-for-stm32/14.3.1+st.2/bin/arm-none-eabi-gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "serverLaunchTimeout": 10000,
            "filterStdout": true,
            "filterStderr": true,
            "serverStarted": "Listening on.*",
            "logging": {
                "moduleLoad": false,
                "trace": false,
                "engineLogging": false,
                "programOutput": false,
                "exceptions": false
            }
        }
    ]
}
