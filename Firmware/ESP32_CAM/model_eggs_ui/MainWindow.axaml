<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1536" d:DesignHeight="864"
        x:Class="model_eggs_ui.MainWindow"
        Title="model_eggs_ui"
        CanResize="False"
        Width="1536" Height="864">

    <Border Background="{DynamicResource PrimaryBackground}">
        <Border Background="{DynamicResource SecondaryBackground}"
                Margin="15"
                CornerRadius="10"
                BoxShadow="0 0 20 -2 black">
            <DockPanel>

                <!-- Top Bar -->
                <Panel Height="70"
                       DockPanel.Dock="Top"
                       Margin="20">
                    <DockPanel HorizontalSpacing="20">
                        <Border Background="{DynamicResource WidgetBackground2}"
                                DockPanel.Dock="Left"
                                Width="70"
                                BoxShadow="5 5 25 -2 black"
                                CornerRadius="10">
                            <Image Source="avares://model_eggs_ui/Assets/logo.png"
                                   Stretch="Uniform"
                                   Margin="8"/>
                        </Border>

                        <Border Background="{DynamicResource WidgetBackground1}"
                                Padding="15"
                                BoxShadow="5 5 25 -2 black"
                                CornerRadius="10">
                            <TextBlock VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="35"
                                       Foreground="{DynamicResource White}"
                                       FontFamily="{DynamicResource NeptuneLander}"
                                       Text="MODEL EGGS"/>
                        </Border>

                        <Border Background="{DynamicResource WidgetBackground2}"
                                BoxShadow="5 5 25 -2 black"
                                CornerRadius="10"/>
                    </DockPanel>
                </Panel>

                <!-- Content -->
                <Grid ColumnDefinitions="* 300 *"
                      ColumnSpacing="30"
                      Margin="20">

                    <!-- DATA / RAW -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Spacing="0"
                                    Height="70">

                            <Button x:Name="DataTabButton"
                                    Click="DataTabButton_Click"
                                    FontSize="30"
                                    Padding="80 20"
                                    CornerRadius="10 10 0 0"
                                    Foreground="{DynamicResource White}"
                                    Background="{DynamicResource WidgetBackground1}"
                                    FontFamily="{DynamicResource NeptuneLander}">
                                DATA
                            </Button>

                            <Button x:Name="RawTabButton"
                                    Click="RawTabButton_Click"
                                    FontSize="30"
                                    Padding="80 20"
                                    CornerRadius="10 10 0 0"
                                    Foreground="{DynamicResource White}"
                                    Background="{DynamicResource WidgetBackground2}"
                                    FontFamily="{DynamicResource NeptuneLander}">
                                RAW
                            </Button>
                        </StackPanel>

                        <Border BoxShadow="15 15 10 -10 black"
                                CornerRadius="0 10 10 10"
                                Background="{DynamicResource WidgetBackground1}"
                                Margin="0 -1 0 0">

                            <Grid>
                                <!-- DATA VIEW -->
                                <Grid x:Name="DataView"
                                      RowDefinitions="* * * *"
                                      RowSpacing="-35"
                                      IsVisible="True">

                                    <Border Grid.Row="0"
                                            Background="{DynamicResource WidgetBackground2}"
                                            Margin="30"
                                            CornerRadius="10"
                                            BoxShadow="5 5 25 -2 black">
                                        <StackPanel>
                                            <TextBlock Text="Vertical Velocity"
                                                       FontFamily="{DynamicResource NeptuneLander}"
                                                       FontSize="25"
                                                       Foreground="{DynamicResource White}"
                                                       Padding="20 15"/>
                                            <TextBlock x:Name="VerticalVelocityValueText"
                                                       Text="0.00 m/s"
                                                       FontSize="40"
                                                       Foreground="{DynamicResource Blue}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Padding="20 0"
                                                       FontFamily="{DynamicResource NeptuneLander}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource WidgetBackground2}"
                                            Margin="30"
                                            CornerRadius="10"
                                            BoxShadow="5 5 25 -2 black">
                                        <StackPanel>
                                            <TextBlock Text="Acceleration"
                                                       FontFamily="{DynamicResource NeptuneLander}"
                                                       FontSize="25"
                                                       Foreground="{DynamicResource White}"
                                                       Padding="20 15"/>
                                            <TextBlock x:Name="AccelerationValueText"
                                                       Text="0.00 m/s²"
                                                       FontSize="40"
                                                       Foreground="{DynamicResource Blue}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Padding="20 0"
                                                       FontFamily="{DynamicResource NeptuneLander}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource WidgetBackground2}"
                                            Margin="30"
                                            CornerRadius="10"
                                            BoxShadow="5 5 25 -2 black">
                                        <StackPanel>
                                            <TextBlock Text="Temperature"
                                                       FontFamily="{DynamicResource NeptuneLander}"
                                                       FontSize="25"
                                                       Foreground="{DynamicResource White}"
                                                       Padding="20 15"/>
                                            <TextBlock x:Name="TemperatureValueText"
                                                       Text="0.00 °C"
                                                       FontSize="40"
                                                       Foreground="{DynamicResource Blue}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Padding="20 0"
                                                       FontFamily="{DynamicResource NeptuneLander}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3"
                                            Background="{DynamicResource WidgetBackground2}"
                                            Margin="30"
                                            CornerRadius="10"
                                            BoxShadow="5 5 25 -2 black">
                                        <StackPanel>
                                            <TextBlock Text="Pressure"
                                                       FontFamily="{DynamicResource NeptuneLander}"
                                                       FontSize="25"
                                                       Foreground="{DynamicResource White}"
                                                       Padding="20 15"/>
                                            <TextBlock x:Name="PressureValueText"
                                                       Text="0.0056 KPA"
                                                       FontSize="40"
                                                       Foreground="{DynamicResource Blue}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Padding="20 0"
                                                       FontFamily="{DynamicResource NeptuneLander}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- RAW VIEW -->
                                <Grid x:Name="RawView"
                                      IsVisible="False"
                                      Margin="20">
                                    <Border Background="{DynamicResource WidgetBackground2}"
                                            CornerRadius="10"
                                            BoxShadow="5 5 25 -2 black"
                                            Padding="15">
                                        <ScrollViewer x:Name="RawScrollViewer"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <TextBlock x:Name="RawLogTextBlock"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource White}"
                                                       FontSize="18"
                                                       FontFamily="Consolas"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DockPanel>

                    <!-- IMG SELECTOR -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource WidgetBackground2}"
                            BoxShadow="5 5 10 -2 black"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontFamily="{DynamicResource NeptuneLander}"
                                       Foreground="{DynamicResource White}"
                                       Text="IMG SELECTOR"
                                       FontSize="30"
                                       TextAlignment="Center"
                                       Padding="20"/>
                            <Border BoxShadow="5 5 10 0 black"
                                    Margin="25 0 25 0"
                                    CornerRadius="10">
                                <Button Content="Latest"
                                        FontFamily="{DynamicResource NeptuneLander}"
                                        Foreground="{DynamicResource White}"
                                        FontSize="25"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource WidgetBackground1}"
                                        Padding="70 10 70 10"
                                        CornerRadius="10"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- IMG VIEWER -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource WidgetBackground1}"
                            CornerRadius="12"
                            BoxShadow="8 8 20 -8 Black">

                        <Grid Margin="22"
                              RowDefinitions="Auto,170,360,Auto"
                              ColumnDefinitions="1*,1*"
                              ColumnSpacing="18"
                              RowSpacing="14">

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="LEFT"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource NeptuneLander}"
                                       FontSize="26"
                                       Foreground="{DynamicResource White}"/>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="RIGHT"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource NeptuneLander}"
                                       FontSize="26"
                                       Foreground="{DynamicResource White}"/>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Width="250"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#24142E"
                                    BorderBrush="{DynamicResource RedLeft}"
                                    BorderThickness="6"
                                    CornerRadius="10"
                                    ClipToBounds="True"
                                    BoxShadow="4 4 16 -6 Black">
                                <Image x:Name="LeftImageControl"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Width="250"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#24142E"
                                    BorderBrush="{DynamicResource BlueRight}"
                                    BorderThickness="6"
                                    CornerRadius="10"
                                    ClipToBounds="True"
                                    BoxShadow="4 4 16 -6 Black">
                                <Image x:Name="RightImageControl"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Width="540"
                                    Height="340"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#24142E"
                                    BorderBrush="{DynamicResource GreenOut}"
                                    BorderThickness="6"
                                    CornerRadius="10"
                                    ClipToBounds="True"
                                    BoxShadow="4 4 16 -6 Black">
                                <Image x:Name="OutputImageControl"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="3"
                                       Grid.ColumnSpan="2"
                                       Text="OUT"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource NeptuneLander}"
                                       FontSize="26"
                                       Foreground="{DynamicResource White}"/>
                        </Grid>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Border>
</Window>